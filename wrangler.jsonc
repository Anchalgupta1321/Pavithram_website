{
  // Deploy the static export (`out/`) as a Cloudflare Workers static-assets site.
  // `npm run build` produces `out/`; `npx wrangler deploy` uploads it.
  "name": "pavithram-website",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".vercel/output/static/_worker.js/index.js",
  "assets": {
    "directory": ".vercel/output/static",
    "binding": "ASSETS"
  }
}
